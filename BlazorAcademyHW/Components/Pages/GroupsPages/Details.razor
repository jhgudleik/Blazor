@page "/groups/details"
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Details - @(groups?.group_name ?? "Group")</PageTitle>

<h1>Details</h1>

<div>
    <h2>Group</h2>
    <hr />
    @if (groups is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <h3>
            <b>Группа @groups.group_name</b>
        </h3>
        <dl class="row">
            <dt class="col-sm-2">ID группы</dt>
            <dd class="col-sm-10">@groups.group_id</dd>

            <dt class="col-sm-2">Направление</dt>
            <dd class="col-sm-10">
                <a href="/directions/details?direction_id=@groups.direction">
                    @(groups.Direction?.direction_name ?? "Не указано")
                </a>
            </dd>

            <dt class="col-sm-2">Учебные дни</dt>
            <dd class="col-sm-10">
                @if (weekInfo != null)
                {
                    <span class="badge btn-primary">
                        @GetDaysString(weekInfo.study_days)
                    </span>
                }
                else
                {
                    <span class="text-muted">Дни не заданы</span>
                }
            </dd>
        </dl>



        @* Секция со списком студентов группы *@
        <h4>Студенты:</h4>
        @if (groupStudents.Any())
        {
            <ul>
                @foreach (var student in groupStudents)
                {
                    <li>
                        <a href="/students/details?stud_id=@student.stud_id" ">
                            @student.last_name @student.first_name @student.middle_name
                        </a>
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="text-muted">В этой группе пока нет студентов.</p>
        }
        <div class="mt-4">
            <p class="text-muted">Всего студентов: @groupStudents.Count</p>
        </div>


        <div class="mt-3">
            <a href="@($"/groups/edit?group_id={groups.group_id}")">Edit</a> |
            <a href="@($"/groups")">Back to List</a>
        </div>
    }
</div>

@code {
    private Groups? groups;
    private Week? weekInfo;
    // Список для хранения студентов данной группы
    private List<Student> groupStudents = new();
    private string[] DayNames = { "Пн", "Вт", "Ср", "Чт", "Пт", "Сб", "Вс" };

    [SupplyParameterFromQuery]
    private int group_id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        // 1. Загружаем данные о группе
        groups = await context.Groups
            .Include(g => g.Direction)
            .FirstOrDefaultAsync(m => m.group_id == group_id);

        if (groups is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        // 2. Загружаем информацию об учебных днях
        weekInfo = await context.Week
            .AsNoTracking()
            .FirstOrDefaultAsync(w => w.grp_id == group_id);

        // 3. Загружаем список студентов, привязанных к этой группе
        // Поле "group" в модели Student — это внешний ключ
        groupStudents = await context.Student
            .AsNoTracking()
            .Where(s => s.group == group_id)
            .OrderBy(s => s.last_name)
            .ThenBy(s => s.first_name)
            .ToListAsync();
    }

    // Метод для декодирования битовой маски дней недели
    private string GetDaysString(byte mask)
    {
        if (mask == 0) return "—";
        var selectedDays = new List<string>();

        for (int i = 0; i < 7; i++)
        {
            if ((mask & (1 << i)) != 0)
            {
                selectedDays.Add(DayNames[i]);
            }
        }
        return string.Join(", ", selectedDays);
    }
}
