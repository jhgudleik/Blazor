@page "/groups/create"
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@using BlazorAcademyHW.Data
@rendermode InteractiveServer

@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Create Group</PageTitle>


<h1>Create</h1>
<h2>Group</h2>
<hr />

<div class="row">
    <div class="col-md-4">
        <EditForm Model="Groups" OnValidSubmit="AddGroups" FormName="createGroup">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert" />

            <div class="mb-3">
                <label for="group_name" class="form-label">Название группы:</label>
                <InputText id="group_name" @bind-Value="Groups.group_name" class="form-control" />
                <ValidationMessage For="() => Groups.group_name" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="directionSelect" class="form-label">Направление:</label>
                <InputSelect @bind-Value="Groups.direction" class="form-select" id="directionSelect">
                    <option value="0">-- Выберите направление --</option>
                    @foreach (var dir in Dirs)
                    {
                        <option value="@dir.direction_id">@dir.direction_name</option>
                    }
                </InputSelect>
                <ValidationMessage For="() => Groups.direction" class="text-danger" />
                <div class="text-muted mt-1">
                    ID направления: <strong>@(Groups.direction == 0 ? "не выбран" : Groups.direction)</strong>
                </div>
            </div>

            <div class="mt-4">
                <h4>Учебные дни:</h4>
                <div class="d-flex flex-wrap gap-1">
                    @for (int i = 0; i < 7; i++)
                    {
                        var index = i;
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="day_@index"
                                   checked="@IsDayChecked(index)"
                                   @onchange="e => ToggleDay(index, (bool)e.Value)" />
                            <label class="form-check-label ms-1" for="day_@index">@Days[index]</label>
                        </div>
                    }
                </div>
                <small class="text-muted mt-1">Текущая маска: @studyDays</small>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Создать</button>
            </div>
        </EditForm>
    </div>
</div>

<div class="mt-3">
    <a href="/groups">Back to List</a>
</div>

@code {
    [SupplyParameterFromForm]
    public Groups Groups { get; set; } = new();

    private List<Directions> Dirs = new();
    private byte studyDays = 0;
    private string[] Days = { "Пн", "Вт", "Ср", "Чт", "Пт", "Сб", "Вс" };

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        Dirs = await context.Directions.AsNoTracking().ToListAsync();
    }

    // Проверяет, установлен ли бит для дня
    private bool IsDayChecked(int dayIndex)
    {
        return (studyDays & (1 << dayIndex)) != 0;
    }

    // Переключает бит дня
    private void ToggleDay(int dayIndex, bool isChecked)
    {
        int bitValue = 1 << dayIndex;
        if (isChecked)
        {
            studyDays = (byte)(studyDays | bitValue);
        }
        else
        {
            studyDays = (byte)(studyDays & ~bitValue);
        }
    }

    private async Task AddGroups()
    {
        if (Groups.direction == 0)
        {
            // Можно показать сообщение об ошибке — например, через ValidationSummary
            return;
        }

        using var context = DbFactory.CreateDbContext();

        context.Groups.Add(Groups);
        await context.SaveChangesAsync(); // Генерирует group_id

        // Теперь, когда Groups.group_id заполнен — добавляем Week
        context.Week.Add(new Week
        {
            grp_id = Groups.group_id,
            study_days = studyDays
        });

        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/groups");
    }
}
