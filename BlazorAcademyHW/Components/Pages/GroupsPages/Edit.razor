@page "/groups/edit"
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@using BlazorAcademyHW.Data
@* Включаем интерактивность для работы привязки данных в реальном времени *@
@rendermode InteractiveServer

@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Edit</PageTitle>

<h1>Edit</h1>
<h2>Groups</h2>
<hr />

@if (Groups is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm Model="Groups" OnValidSubmit="UpdateGroups" FormName="editGroup">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" role="alert" />

                <div class="mb-3">
                    <label for="group_id" class="form-label">Group ID:</label>
                    <strong id="group_id">@Groups.group_id</strong>
                </div>

                <div class="mb-3">
                    <label for="group_name" class="form-label">Group Name:</label>
                    <InputText id="group_name" @bind-Value="Groups.group_name" class="form-control" />
                    <ValidationMessage For="() => Groups.group_name" class="text-danger" />
                </div>

                <div class="mb-3">
                    <label for="directionSelect" class="form-label">Direction:</label>

                    @* Используем InputSelect для выбора направления из списка *@
                    <InputSelect id="directionSelect" @bind-Value="Groups.direction" class="form-select">
                        <option value="0">-- Select Direction --</option>
                        @foreach (var dir in Dirs)
                        {
                            <option value="@dir.direction_id">@dir.direction_name</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="() => Groups.direction" class="text-danger" />

                    <div class="mt-3">
                        <label for="direction_id" class="form-label">Direction ID: </label>
                        <strong id="direction_id">@(Groups.direction == 0 ? "не выбран" : Groups.direction)</strong>
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Save</button>
                    <a href="/groups" class="btn btn-secondary">Cancel</a>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery]
    private int group_id { get; set; }

    [SupplyParameterFromForm]
    public Groups? Groups { get; set; }

    // Список всех доступных направлений
    private List<Directions> Dirs = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        // 1. Загружаем список направлений для выпадающего списка
        Dirs = await context.Directions.AsNoTracking().ToListAsync();

        // 2. Загружаем саму группу, если она еще не загружена из формы
        if (Groups is null)
        {
            Groups = await context.Groups.FirstOrDefaultAsync(m => m.group_id == group_id);
        }

        if (Groups is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task UpdateGroups()
    {
        if (Groups is null) return;

        using var context = DbFactory.CreateDbContext();

        // Помечаем сущность как измененную
        context.Attach(Groups).State = EntityState.Modified;

        try
        {
            await context.SaveChangesAsync();
            NavigationManager.NavigateTo("/groups");
        }
        catch (DbUpdateConcurrencyException)
        {
            if (!GroupsExists(Groups.group_id))
            {
                NavigationManager.NavigateTo("notfound");
            }
            else
            {
                throw;
            }
        }
    }

    private bool GroupsExists(int group_id)
    {
        using var context = DbFactory.CreateDbContext();
        return context.Groups.Any(e => e.group_id == group_id);
    }
}
