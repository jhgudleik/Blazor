@page "/students/edit"
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@using Microsoft.AspNetCore.Components.Forms
@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory
@inject NavigationManager NavigationManager

@rendermode InteractiveServer

<PageTitle>Edit student</PageTitle>

<h1>Edit</h1>
<h2>student</h2>
<hr />

@if (student is null)
{
    <p><em>Loading…</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm Model="student" OnValidSubmit="Updatestudent">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" role="alert" />

                <div class="mb-3">
                    <label class="form-label">Фамилия:</label>
                    <InputText @bind-Value="student.last_name" class="form-control" />
                    <ValidationMessage For="() => student.last_name" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Имя:</label>
                    <InputText @bind-Value="student.first_name" class="form-control" />
                    <ValidationMessage For="() => student.first_name" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Отчество:</label>
                    <InputText @bind-Value="student.middle_name" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Дата рождения:</label>
                    <InputDate @bind-Value="student.birth_date" class="form-control" />
                    <ValidationMessage For="() => student.birth_date" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Email:</label>
                    <InputText @bind-Value="student.email" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Телефон:</label>
                    <InputText @bind-Value="student.phone" class="form-control" />
                </div>

                <!-- Блок фото -->
                <div class="mb-3">
                    <label for="photo" class="form-label">Фото:</label>
                    <InputFile id="photo"
                               OnChange="HandleFileSelected"
                               class="form-control"
                               accept="image/*" />

                    @if (!string.IsNullOrEmpty(previewUrl))
                    {
                        <div class="mt-2">
                            <img src="@previewUrl"
                                 alt="Preview"
                                 style="max-width:200px;max-height:200px;"
                                 class="img-thumbnail" />
                        </div>
                    }
                    else if (student.photo is { Length: > 0 })
                    {
                        <!-- показываем уже сохранённое фото -->
                        <div class="mt-2">
                            <img src="@($"data:image/jpeg;base64,{Convert.ToBase64String(student.photo)}")"
                                 alt="Current photo"
                                 style="max-width:200px;max-height:200px;"
                                 class="img-thumbnail" />
                        </div>
                    }
                </div>

                <div class="mb-3">
                    <label class="form-label">Группа:</label>
                    <InputNumber @bind-Value="student.group" class="form-control" />
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/students">Back to List</a>
</div>

@code {
    [Parameter, SupplyParameterFromQuery] public int stud_id { get; set; }

    private Student? student { get; set; }
    private string? previewUrl;

    protected override async Task OnInitializedAsync()
    {
        using var ctx = DbFactory.CreateDbContext();
        student = await ctx.Student
                             .AsNoTracking()
                             .FirstOrDefaultAsync(s => s.stud_id == stud_id);
        if (student is null)
            NavigationManager.NavigateTo("notfound");
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        long maxBytes = 10 * 1024 * 1024; // 10 МБ
        using var stream = file.OpenReadStream(maxBytes);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);

        student!.photo = ms.ToArray();
        previewUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(student.photo)}";
    }

    private async Task Updatestudent()
    {
        using var ctx = DbFactory.CreateDbContext();
        ctx.Student.Update(student!);
        await ctx.SaveChangesAsync();
        NavigationManager.NavigateTo("/students");
    }
}
