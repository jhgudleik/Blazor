@page "/students/create"
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@using Microsoft.AspNetCore.Components.Forms
@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory
@inject NavigationManager NavigationManager

@* 
   Добавляем интерактивный режим рендеринга. 
   Без него HandleFileSelected и OnValidSubmit не смогут корректно 
   взаимодействовать с сервером для передачи бинарных данных.
*@
@rendermode InteractiveServer

<PageTitle>Create Student</PageTitle>

<h1>Create</h1>
<h2>Student</h2>
<hr />

<div class="row">
    <div class="col-md-4">
        @* 
           Удаляем метод "post" и FormName, так как в интерактивном режиме 
           Blazor сам обработает отправку через сокеты.
        *@
        <EditForm Model="Student" OnValidSubmit="AddStudent">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert" />

            <div class="mb-3">
                <label for="last_name" class="form-label">Фамилия:</label>
                <InputText id="last_name" @bind-Value="Student.last_name" class="form-control" />
                <ValidationMessage For="() => Student.last_name" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="first_name" class="form-label">Имя:</label>
                <InputText id="first_name" @bind-Value="Student.first_name" class="form-control" />
                <ValidationMessage For="() => Student.first_name" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="middle_name" class="form-label">Отчество:</label>
                <InputText id="middle_name" @bind-Value="Student.middle_name" class="form-control" />
            </div>

            <div class="mb-3">
                <label for="birth_date" class="form-label">Дата рождения:</label>
                <InputDate id="birth_date" @bind-Value="Student.birth_date" class="form-control" />
                <ValidationMessage For="() => Student.birth_date" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="email" class="form-label">Email:</label>
                <InputText id="email" @bind-Value="Student.email" class="form-control" />
            </div>

            <div class="mb-3">
                <label for="phone" class="form-label">Телефон:</label>
                <InputText id="phone" @bind-Value="Student.phone" class="form-control" />
            </div>

            <div class="mb-3">
                <label for="photo" class="form-label">Фото:</label>
                <InputFile id="photo" OnChange="HandleFileSelected" class="form-control" accept="image/*" />

                @if (!string.IsNullOrEmpty(previewUrl))
                {
                    <div class="mt-2">
                        <img src="@previewUrl" alt="Preview" style="max-width: 200px; max-height: 200px;" class="img-thumbnail" />
                    </div>
                }
            </div>

            <div class="mb-3">
                <label for="group" class="form-label">Группа:</label>
                <InputNumber id="group" @bind-Value="Student.group" class="form-control" />
            </div>

            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/students">Back to List</a>
</div>

@code {
    // В интерактивном режиме атрибут [SupplyParameterFromForm] не обязателен
    private Student Student { get; set; } = new();

    private string? previewUrl;

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            // Увеличиваем лимит для считывания (например, до 10 МБ)
            long maxAllowedSize = 1024 * 1024 * 10;

            using var stream = file.OpenReadStream(maxAllowedSize);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);

            // Присваиваем массив байт свойству модели
            Student.photo = ms.ToArray();

            // Создаем превью для интерфейса
            previewUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(Student.photo)}";
        }
    }

    private async Task AddStudent()
    {
        try
        {
            using var context = DbFactory.CreateDbContext();

            // Тщательно проверяем, что массив байт в Student.photo не пустой перед сохранением
            context.Student.Add(Student);
            await context.SaveChangesAsync();

            NavigationManager.NavigateTo("/students");
        }
        catch (Exception ex)
        {
            // Здесь можно обработать ошибку сохранения
            Console.WriteLine($"Error saving student: {ex.Message}");
        }
    }
}
