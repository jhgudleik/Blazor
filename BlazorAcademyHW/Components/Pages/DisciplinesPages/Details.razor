@page "/disciplines/details"
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Details</PageTitle>

<h1>Details</h1>

<div>
    <h2>Discipline</h2>
    <hr />

    @if (discipline is null)
    {
        <p><em>Loading…</em></p>
    }
    else
    {
        <dl class="row">
            <dt class="col-sm-2">Название</dt>
            <dd class="col-sm-10">@discipline.discipline_name</dd>

            <dt class="col-sm-2">Кол-во занятий</dt>
            <dd class="col-sm-10">@discipline.number_of_lessons</dd>
        </dl>


        <!-- Блок преподаватели -->
        <h4>Преподаватели:</h4>
        @if (teachers.Any())
        {
            <ul>
                @foreach (var t in teachers)
                {
                    <li>
                        <a href="/teachers/details?teacher_id=@t.teacher_id">
                            @t.last_name @t.first_name @t.middle_name
                        </a>
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="text-muted">Преподаватели пока не назначены.</p>
        }


        <!-- Блок направлений -->
        <h4>Направления:</h4>
        @if (directions.Any())
        {
            <ul>
            
                @foreach (var dir in directions)
                {
                    <li>
                        <a href="/directions/details?direction_id=@dir.direction_id">
                            @dir.direction_name
                        </a>
                    </li>

                    
                }
            
            </ul>
        }
        else
        {
            <p class="text-muted">Направления не указаны.</p>
        }


        <div class="mt-3">
            <a href="@($"disciplines/edit?discipline_id={discipline.discipline_id}")">Edit</a> |
            <a href="/disciplines">Back to List</a>
        </div>
    }
</div>

@code {
    private Disciplines? discipline;
    private List<Teachers> teachers = new();
    private List<Directions> directions = new(); // Список для хранения направлений

    [SupplyParameterFromQuery]
    private int discipline_id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var ctx = DbFactory.CreateDbContext();

        // 1. Загружаем основную информацию о дисциплине
        discipline = await ctx.Disciplines
                              .AsNoTracking()
                              .FirstOrDefaultAsync(d => d.discipline_id == discipline_id);

        if (discipline is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        // 2. Загружаем направления через таблицу связей
        // Используем Select для получения сразу объектов Directions через навигационное свойство
        directions = await ctx.DisciplinesDirectionsRelation
                              .AsNoTracking()
                              .Where(r => r.discipline == discipline_id)
                              .Select(r => r.DirectionNavigation)
                              .ToListAsync();

        // 3. Загружаем преподавателей
        teachers = await ctx.Teachers
                            .AsNoTracking()
                            .Where(t => ctx.TeachersDisciplinesRelation
                                           .Any(r => r.discipline == discipline_id && r.teacher == t.teacher_id))
                            .ToListAsync();
    }
}
