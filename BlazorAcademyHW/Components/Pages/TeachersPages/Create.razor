@page "/teachers/create"
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@using Microsoft.AspNetCore.Components.Forms
@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Create teacher</PageTitle>

<h1>Create</h1>
<h2>teacher</h2>
<hr />

<div class="row">
    <div class="col-md-4">
        <EditForm Model="teacher" OnValidSubmit="Addteacher">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert" />

            <div class="mb-3">
                <label for="last_name" class="form-label">Фамилия:</label>
                <InputText id="last_name" @bind-Value="teacher.last_name" class="form-control" />
                <ValidationMessage For="() => teacher.last_name" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="first_name" class="form-label">Имя:</label>
                <InputText id="first_name" @bind-Value="teacher.first_name" class="form-control" />
                <ValidationMessage For="() => teacher.first_name" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="middle_name" class="form-label">Отчество:</label>
                <InputText id="middle_name" @bind-Value="teacher.middle_name" class="form-control" />
            </div>

            <div class="mb-3">
                <label for="birth_date" class="form-label">Дата рождения:</label>
                <InputDate id="birth_date" @bind-Value="teacher.birth_date" class="form-control" />
                <ValidationMessage For="() => teacher.birth_date" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="email" class="form-label">Email:</label>
                <InputText id="email" @bind-Value="teacher.email" class="form-control" />
            </div>

            <div class="mb-3">
                <label for="phone" class="form-label">Телефон:</label>
                <InputText id="phone" @bind-Value="teacher.phone" class="form-control" />
            </div>

            <!-- Фото -->
            <div class="mb-3">
                <label for="photo" class="form-label">Фото:</label>
                <InputFile id="photo" OnChange="HandleFileSelected" class="form-control" accept="image/*" />
                @if (!string.IsNullOrEmpty(previewUrl))
                {
                    <div class="mt-2">
                        <img src="@previewUrl" alt="Preview" style="max-width:200px;max-height:200px;" class="img-thumbnail" />
                    </div>
                }
            </div>

            <div class="mb-3">
                <label for="work_since" class="form-label">Работает с:</label>
                <InputDate id="work_since" @bind-Value="teacher.work_since" class="form-control" />
            </div>

            <div class="mb-3">
                <label for="rate" class="form-label">Ставка:</label>
                <InputNumber id="rate" @bind-Value="teacher.rate" class="form-control" />
            </div>

            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/teachers">Back to List</a>
</div>

@code {
    private Teachers teacher { get; set; } = new();
    private string? previewUrl;

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        long maxBytes = 10 * 1024 * 1024; // 10 МБ
        using var stream = file.OpenReadStream(maxBytes);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);

        teacher.photo = ms.ToArray();
        previewUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(teacher.photo)}";
    }

    private async Task Addteacher()
    {
        try
        {
            using var ctx = DbFactory.CreateDbContext();
            ctx.Teachers.Add(teacher);
            await ctx.SaveChangesAsync();
            NavigationManager.NavigateTo("/teachers");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving teacher: {ex.Message}");
        }
    }
}
