@page "/teachers/edit"
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@using Microsoft.AspNetCore.Components.Forms
@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Edit Teacher</PageTitle>

<h1>Edit</h1>
<h2>Teacher</h2>
<hr />

@if (teacher is null)
{
    <p><em>Loading…</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm Model="teacher" OnValidSubmit="UpdateTeacher">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" role="alert" />

                <div class="mb-3">
                    <label class="form-label">Фамилия:</label>
                    <InputText @bind-Value="teacher.last_name" class="form-control" />
                    <ValidationMessage For="() => teacher.last_name" class="text-danger" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Имя:</label>
                    <InputText @bind-Value="teacher.first_name" class="form-control" />
                    <ValidationMessage For="() => teacher.first_name" class="text-danger" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Отчество:</label>
                    <InputText @bind-Value="teacher.middle_name" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Дата рождения:</label>
                    <InputDate @bind-Value="teacher.birth_date" class="form-control" />
                    <ValidationMessage For="() => teacher.birth_date" class="text-danger" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Email:</label>
                    <InputText @bind-Value="teacher.email" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Телефон:</label>
                    <InputText @bind-Value="teacher.phone" class="form-control" />
                </div>

                <!-- Блок фото -->
                <div class="mb-3">
                    <label for="photo" class="form-label">Фото:</label>
                    <InputFile id="photo" OnChange="HandleFileSelected" class="form-control" accept="image/*" />

                    @if (!string.IsNullOrEmpty(previewUrl))
                    {
                        <div class="mt-2">
                            <img src="@previewUrl" alt="Preview" style="max-width:200px;max-height:200px;" class="img-thumbnail" />
                        </div>
                    }
                    else if (teacher.photo is { Length: > 0 })
                    {
                        <div class="mt-2">
                            <img src="@($"data:image/jpeg;base64,{Convert.ToBase64String(teacher.photo)}")"
                                 alt="Current photo" style="max-width:200px;max-height:200px;" class="img-thumbnail" />
                        </div>
                    }
                </div>

                <div class="mb-3">
                    <label class="form-label">Работает с:</label>
                    <InputDate @bind-Value="teacher.work_since" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Ставка:</label>
                    <InputNumber @bind-Value="teacher.rate" class="form-control" />
                </div>

                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/teachers">Back to List</a>
</div>

@code {
    [Parameter, SupplyParameterFromQuery] public int teacher_id { get; set; }

    private Teachers? teacher;
    private string? previewUrl;

    protected override async Task OnInitializedAsync()
    {
        using var ctx = DbFactory.CreateDbContext();
        teacher = await ctx.Teachers
                             .AsNoTracking()
                             .FirstOrDefaultAsync(t => t.teacher_id == teacher_id);

        if (teacher is null)
            NavigationManager.NavigateTo("notfound");
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        long maxBytes = 10 * 1024 * 1024; // 10 МБ
        using var stream = file.OpenReadStream(maxBytes);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);

        teacher!.photo = ms.ToArray();
        previewUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(teacher.photo)}";
    }

    private async Task UpdateTeacher()
    {
        using var ctx = DbFactory.CreateDbContext();
        ctx.Teachers.Update(teacher!);
        await ctx.SaveChangesAsync();
        NavigationManager.NavigateTo("/teachers");
    }
}
