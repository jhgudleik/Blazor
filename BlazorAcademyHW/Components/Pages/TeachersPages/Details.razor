@page "/teachers/details"
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Details</PageTitle>

<h1>Details</h1>

<div>
    <h2>Teacher</h2>
    @if (teacher is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <div class="row">
            <div class="col-md-4">
                @if (teacher.photo != null)
                {
                    <div class="mt-2">
                        <img src="@($"data:image/jpeg;base64,{Convert.ToBase64String(teacher.photo)}")"
                             alt="Current photo"
                             style="max-width:200px;max-height:200px;"
                             class="img-thumbnail" />
                    </div>
                }
                else
                {
                    <div class="alert alert-secondary mt-2">Нет фото</div>
                }
            </div>

            <div class="col-md-8">
                <hr />
                <dl class="row">
                    <dt class="col-sm-3">Фамилия</dt>
                    <dd class="col-sm-9">@teacher.last_name</dd>

                    <dt class="col-sm-3">Имя</dt>
                    <dd class="col-sm-9">@teacher.first_name</dd>

                    <dt class="col-sm-3">Отчество</dt>
                    <dd class="col-sm-9">@teacher.middle_name</dd>

                    <dt class="col-sm-3">Дата рождения</dt>
                    <dd class="col-sm-9">@teacher.birth_date?.ToString("dd.MM.yyyy")</dd>

                    <dt class="col-sm-3">Email</dt>
                    <dd class="col-sm-9">@teacher.email</dd>

                    <dt class="col-sm-3">Телефон</dt>
                    <dd class="col-sm-9">@teacher.phone</dd>

                    <dt class="col-sm-3">Работает с</dt>
                    <dd class="col-sm-9">@teacher.work_since?.ToString("dd.MM.yyyy")</dd>

                    <dt class="col-sm-3">Ставка</dt>
                    <dd class="col-sm-9">@teacher.rate?.ToString("C")</dd>
                </dl>
            </div>
        </div>

        <div class="mt-4">
            <h4>Дисциплины:</h4>
            @if (assignedDisciplines == null || !assignedDisciplines.Any())
            {
                <p class="text-muted">Для данного преподавателя дисциплины не назначены.</p>
            }
            else
            {
                <ul class="list-group col-md-7">
                    @foreach (var disc in assignedDisciplines)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <a href="/disciplines/details?discipline_id=@disc.discipline_id">
                                @disc.discipline_name
                            </a>
                                <span class="badge btn-primary">@disc.number_of_lessons занятий</span>

                        </li>
                    }
                </ul>
            }
        </div>

        <div>
            <a href="@($"/teachers/edit?teacher_id={teacher.teacher_id}")">Edit</a> |
            <a href="@($"/teachers")">Back to List</a>
        </div>
    }
</div>

@code {
    private Teachers? teacher;
    private List<Disciplines> assignedDisciplines = new();

    [SupplyParameterFromQuery]
    private int teacher_id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        // Получаем данные преподавателя
        teacher = await context.Teachers.FirstOrDefaultAsync(m => m.teacher_id == teacher_id);

        if (teacher is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        // Загружаем связанные дисциплины через Join
        assignedDisciplines = await (from rel in context.TeachersDisciplinesRelation
                                     join disc in context.Disciplines on rel.discipline equals disc.discipline_id
                                     where rel.teacher == teacher_id
                                     select disc).ToListAsync();
    }
}
