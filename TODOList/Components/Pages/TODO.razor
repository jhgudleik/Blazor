@page "/todo"
@rendermode InteractiveServer

<PageTitle>TODO</PageTitle>
<h3>TODO</h3>
<div class="statistics">
    <h5>Всего заданий: @taskList.Count</h5>
    <h5>Выполненных заданий: @taskList.Where(t => t.DONE == true).ToList().Count</h5>
    <h5>Осталось: @taskList.Where(t => t.DONE == false).ToList().Count</h5>
</div>
<input placeholder="Новая задача" @bind="task" @onkeyup="Enter" />
<button @onclick="AddTask">Добавить</button>
<ul class="tasklist">
    @foreach (TODOitem i in taskList)
    {
        <li>
            <input type="checkbox" @bind="i.DONE" id="@i.Title"/>
            <label for="@i.Title" class=@(i.DONE ? "done" : "")>@i.Title</label>
        </li>
}
</ul>
@code {
    List<TODOitem> taskList = [];
    string task;
    void AddTask()
    {
        if ((!string.IsNullOrWhiteSpace(task)) && !taskList.Contains(new TODOitem {Title = task}))
        {
            taskList.Add(new TODOitem { Title = task });
            task = "";
        }

    }
    void Enter(KeyboardEventArgs e)
    {
        if(e.Key == "Enter") AddTask();
    }
}
