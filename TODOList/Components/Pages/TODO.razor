@page "/todo"
@rendermode InteractiveServer

<PageTitle>TODO</PageTitle>
<h3>TODO</h3>
<input placeholder="Новая задача" @bind="task" />
<button @onclick="AddTask">Добавить</button>
<ul>
    @foreach (TODOitem i in taskList)
    {
        <li>@i.Title</li>
}
</ul>

@code {
    List<TODOitem> taskList = [];
    string task;
    void AddTask()
    {
        if (string.IsNullOrWhiteSpace(task))
        {
            taskList.Add(new TODOitem { Title = task });
        }

    }

}
