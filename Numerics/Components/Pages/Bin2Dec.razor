@page "/bin2dec"
@rendermode InteractiveServer

<h3>BIN → DEC</h3>

<div class="converter">
    <input type="text"
           pattern="[01]*"
           value="@bin"
           @oninput="OnBinInput"
           @onkeydown="OnKey"
           placeholder="двоичное число (0 и 1)"
           title="только 0 и 1"
           @ref="inputRef" />

    <div class="result"> → @dec</div>
</div>

@code {
    private string bin = "0";
    private long dec;
    private ElementReference inputRef;

    /* ---------- ввод / фильтр ---------- */
    private void OnBinInput(ChangeEventArgs e)
    {
        var clean = new string((e.Value?.ToString() ?? "")
                              .Where(c => c is '0' or '1')
                              .ToArray());
        clean = System.Text.RegularExpressions.Regex.Replace(clean, "^0+(?!$)", "");
        if (string.IsNullOrEmpty(clean)) clean = "0";
        bin = clean;
        dec = Convert.ToInt64(bin, 2);
    }

    /* ---------- стрелки внутри поля ---------- */
    private void OnKey(KeyboardEventArgs e)
    {
        if (e.Code == "ArrowUp") { Increment(); }
        if (e.Code == "ArrowDown") { Decrement(); }
    }

    private void Increment() => Step(+1);
    private void Decrement() => Step(-1);

    private void Step(int delta)
    {
        dec = Math.Max(0, dec + delta);
        bin = Convert.ToString(dec, 2);
        StateHasChanged();          // обновляем поле
        _ = inputRef.FocusAsync();  // возвращаем фокус
    }
}
